# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_PATH=../database/customers.db

# Customer Profiles Path (local directory of source documents to import)
CUSTOMER_PROFILES_PATH=./data/customer_profiles

# Auth
JWT_SECRET=change-me-in-production

# RoofLink CRM API Credentials
ROOFLINK_API_KEY=your_rooflink_api_key_here
ROOFLINK_BEARER_TOKEN=your_rooflink_session_bearer_token_here
ROOFLINK_EMAIL=you@example.com
COMPANY_ID=your_company_id_here
COMPANY_NAME=your_company_abbreviation_here

# CompanyCam API Credentials
COMPANYCAM_TOKEN_1=your_companycam_token_1_here
COMPANYCAM_TOKEN_2=your_companycam_token_2_here

# Email (IMAP/SMTP) for supplement email tracking
EMAIL_PASSWORD=your_email_app_password_here
